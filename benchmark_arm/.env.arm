# =============================================================================
# Backend ARM — Samsung Galaxy S24 (Snapdragon 8 Gen 3, 8 GB LPDDR5X)
# =============================================================================
# Dispositivo alvo para o TCC:
#   SoC  : Qualcomm Snapdragon 8 Gen 3 (SM8650)
#   CPU  : 1x Cortex-X4 @ 3.39 GHz + 3x Cortex-A720 @ 3.1 GHz
#          + 2x Cortex-A720 @ 2.9 GHz + 2x Cortex-A530 @ 2.2 GHz
#   RAM  : 8 GB LPDDR5X (largura de banda teórica ~77 GB/s; efetiva ~34 GB/s)
#   ISA  : AArch64, NEON/ASIMD, SVE2, DotProd, i8mm
#   GPU  : Adreno 750 (não utilizado neste backend — CPU-only)
# =============================================================================

EXPERIMENT_NAME=ELIB_Edge_Benchmark_ARM

# ── Binários llama.cpp compilados para AArch64 ────────────────────────────────
# Ajuste o caminho conforme onde você compilou o llama.cpp no dispositivo/Termux
LLAMA_COMPLETION_PATH=../../llama.cpp/build/bin/llama-completion
LLAMA_BENCH_PATH=../../llama.cpp/build/bin/llama-bench
LLAMA_PERPLEXITY_PATH=../../llama.cpp/build/bin/llama-perplexity

# ── Descoberta de modelos ─────────────────────────────────────────────────────
# MODEL_PATHS=model/Llama-3.2-1B-Instruct-Q4_K_M.gguf
MODEL_GLOB=model/*.gguf

OUTPUT_JSON_PATH=output/saida_benchmark_arm.json
DATASET_ROOT=datasets

# ── Tamanhos de amostra (reduzidos para uso em mobile) ───────────────────────
# Com 8 GB de RAM e tempo de inferência mais alto em ARM, amostras menores
# garantem que o benchmark termine antes do timeout do Android matar o processo.
SAMPLE_SIZE_ENEM_2022=0
SAMPLE_SIZE_ENEM_2023=0
SAMPLE_SIZE_ENEM_2024=0
SAMPLE_SIZE_BBQ_GENDER_IDENTITY=0
SAMPLE_SIZE_BBQ_PHYSICAL_APPEARANCE=0
SAMPLE_SIZE_BBQ_RACE_ETHNICITY=0
SAMPLE_SIZE_POETAV2_GSM8K=0
SAMPLE_SIZE_POETAV2_WIKITEXT=0

# ── Modo somente llama-bench ──────────────────────────────────────────────────
# true = pula todos os datasets e perplexidade, roda apenas llama-bench.
BENCH_ONLY=true

# ── Parâmetros de contexto e geração ─────────────────────────────────────────
# CTX_SIZE conservador para não exceder o budget de RAM do Snapdragon 8 Gen 3.
# Com um modelo Q4_K_M de 1-3B, 2048 tokens cabe confortavelmente em ~4-5 GB.
CTX_SIZE=1024
N_PREDICT=128

# ── Threads ───────────────────────────────────────────────────────────────────
# Apenas os 4 núcleos de alto desempenho (Cortex-X4 + A720 prime).
# Usar todos os 8 cores reduz a frequência via thermal throttling no S24.
THREADS=6

# ── Sampling ──────────────────────────────────────────────────────────────────
TEMP=0.0
TOP_K=40
TOP_P=0.95
REPEAT_LAST_N=64

# ── GPU ───────────────────────────────────────────────────────────────────────
# Backend CPU-only. Adreno 750 não é suportado pelo llama.cpp via Vulkan
# sem compilação específica. Mude para N_GPU_LAYERS=-1 se usar backend Vulkan.
N_GPU_LAYERS=0

# ── Largura de banda de memória ───────────────────────────────────────────────
# LPDDR5X do S24: ~77 GB/s teórico; efetivo para LLM CPU-only ≈ 34 GB/s
# (medido com llama-bench, descontando overhead do SO e hermal throttling).
HARDWARE_BANDWIDTH_GBS=34.1

# ── Timeout ───────────────────────────────────────────────────────────────────
# Aumentado em relação ao CPU desktop: ARM mobile é mais lento e pode sofrer
# throttling térmico. 300 s garante que inferências longas não sejam abortadas
# prematuramente, mas ainda protege contra travadas de OOM.
INFERENCE_TIMEOUT_S=300

# ── Stop tokens ───────────────────────────────────────────────────────────────
STOP_TOKENS=</s>|<|eot_id|>|<|im_end|>|<|endoftext|>|<|end_of_text|>|###|User:
STOP_TOKENS_MODE=always

# ── Anti-loop ─────────────────────────────────────────────────────────────────
FLASH_ATTN=false
MAX_REPEAT_NGRAM=8

# ── llama-bench ───────────────────────────────────────────────────────────────
# Menos repetições para economizar tempo e resistência térmica no celular.
BENCH_REPETITIONS=1
BENCH_N_PROMPT=128
BENCH_N_GEN=64

# ── Perplexidade ─────────────────────────────────────────────────────────────
PERPLEXITY_WIKITEXT_ROWS=8
