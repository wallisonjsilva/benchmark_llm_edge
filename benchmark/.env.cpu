# Backend CPU
EXPERIMENT_NAME=ELIB_Edge_Benchmark
LLAMA_COMPLETION_PATH=../../llama.cpp/build/bin/llama-completion
LLAMA_BENCH_PATH=../../llama.cpp/build/bin/llama-bench
LLAMA_PERPLEXITY_PATH=../../llama.cpp/build/bin/llama-perplexity

# Model discovery (prefer MODEL_PATHS, fallback MODEL_GLOB)
# MODEL_PATHS=model/Qwen3-8b-Q4_K_M.gguf
MODEL_GLOB=model/*.gguf

OUTPUT_JSON_PATH=output/saida_benchmark_poetav2.json
DATASET_ROOT=datasets

SAMPLE_SIZE_ENEM=10
SAMPLE_SIZE_BBQ=10
SAMPLE_SIZE_POETAV2=10
SAMPLE_SIZE_ENEM_2022=15
SAMPLE_SIZE_ENEM_2023=15
SAMPLE_SIZE_ENEM_2024=15
SAMPLE_SIZE_BBQ_GENDER_IDENTITY=10
SAMPLE_SIZE_BBQ_PHYSICAL_APPEARANCE=10
SAMPLE_SIZE_BBQ_RACE_ETHNICITY=10
SAMPLE_SIZE_POETAV2_LOGIQA=10
SAMPLE_SIZE_POETAV2_GSM8K=10
SAMPLE_SIZE_POETAV2_COQA=10
SAMPLE_SIZE_POETAV2_TRIVIAQA=10
SAMPLE_SIZE_POETAV2_ARITHMETIC=10
SAMPLE_SIZE_POETAV2_WIKITEXT=10

CTX_SIZE=2048
N_PREDICT=64
THREADS=8
TEMP=0.0
TOP_K=40
TOP_P=0.95
REPEAT_LAST_N=64

N_GPU_LAYERS=0
HARDWARE_BANDWIDTH_GBS=45.0
INFERENCE_TIMEOUT_S=180
STOP_TOKENS=</s>|<|eot_id|>|<|im_end|>|<|endoftext|>|<|end_of_text|>|###|User:
STOP_TOKENS_MODE=always
MAX_REPEAT_NGRAM=8
BENCH_REPETITIONS=3
BENCH_N_PROMPT=256
BENCH_N_GEN=128
PERPLEXITY_WIKITEXT_ROWS=16
